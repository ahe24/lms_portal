<%- include('../partials/head') %>
    <%- include('../partials/sidebar') %>

        <div class="page-header">
            <h1>강의 사이트 관리</h1>
            <p>연동할 강의 사이트를 등록합니다. (직접 등록한 사이트만 삭제 가능)</p>
        </div>

        <div class="card mb-2">
            <div class="card-header">
                <span class="card-title">➕ 새 강의 사이트 등록</span>
            </div>
            <form method="POST" action="/instructor/sites">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">슬러그 (영문, 하이픈 가능)</label>
                        <input type="text" name="slug" class="form-input" placeholder="예: fpga-lect" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">사이트 이름</label>
                        <input type="text" name="name" class="form-input" placeholder="예: FPGA 설계 실습" required>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">URL</label>
                    <input type="url" name="url" class="form-input" placeholder="예: http://localhost:5174" required>
                </div>
                <div class="form-group">
                    <label class="form-label">설명</label>
                    <textarea name="description" class="form-input" placeholder="강의 사이트 설명"></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">🔒 사이트 접근 유형</label>
                    <div style="display: flex; gap: 1.5rem; margin-top: 0.4rem;">
                        <label class="checkbox-item" style="cursor:pointer;">
                            <input type="radio" name="is_public" value="0" checked>
                            <span>🔒 내부 강의 사이트 <small class="text-muted">(수강 승인된 학생 전용)</small></span>
                        </label>
                        <label class="checkbox-item" style="cursor:pointer;">
                            <input type="radio" name="is_public" value="1">
                            <span>🌐 외부 참고 사이트 <small class="text-muted">(로그인 사용자 누구나)</small></span>
                        </label>
                    </div>
                    <small class="text-muted text-sm" style="margin-top: 0.3rem; display:block;">직접 제작한 강의 사이트는 "내부", 공식
                        문서 등 참고용 외부 사이트는 "외부"를 선택하세요.</small>
                </div>
                <div class="form-group">
                    <label class="checkbox-label">
                        <input type="checkbox" name="is_shared" value="1" checked>
                        <span>다른 강사와 공유 (다른 강사가 자신의 강의에 이 사이트를 추가할 수 있습니다)</span>
                    </label>
                </div>
                <button type="submit" class="btn btn-primary">등록</button>
            </form>
        </div>

        <div class="card">
            <div class="card-header">
                <span class="card-title">🌐 내 사이트 목록 (<%= mySites.length %>)</span>
            </div>
            <% if (mySites.length===0) { %>
                <div class="empty-state">
                    <div class="empty-icon">🌐</div>
                    <h3>등록된 사이트가 없습니다</h3>
                </div>
                <% } else { %>
                    <div class="table-wrap">
                        <table>
                            <thead>
                                <tr>
                                    <th>슬러그</th>
                                    <th>이름</th>
                                    <th>유형</th>
                                    <th>URL</th>
                                    <th>설명</th>
                                    <th>공유</th>
                                    <th>관리</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% mySites.forEach(s=> { %>
                                    <tr>
                                        <td><code><%= s.slug %></code></td>
                                        <td><strong>
                                                <%= s.name %>
                                            </strong></td>
                                        <td>
                                            <% if (s.is_public) { %>
                                                <span class="badge badge-info" title="로그인 사용자 누구나 접근 가능">🌐 외부</span>
                                                <% } else { %>
                                                    <span class="badge"
                                                        style="background:var(--accent-glow,rgba(99,102,241,.15));color:var(--accent,#818cf8);"
                                                        title="수강 승인된 학생만 접근 가능">🔒 내부</span>
                                                    <% } %>
                                        </td>
                                        <td class="text-sm">
                                            <%= s.url %>
                                        </td>
                                        <td class="text-sm text-muted">
                                            <%= s.description || '-' %>
                                        </td>
                                        <td>
                                            <form method="POST" action="/instructor/sites/<%= s.id %>/toggle-share"
                                                style="display:inline;">
                                                <button type="submit"
                                                    class="btn btn-sm <%= s.is_shared ? 'btn-success' : 'btn-outline' %>"
                                                    title="<%= s.is_shared ? '공유 중' : '비공유' %>">
                                                    <%= s.is_shared ? '✓ 공유 중' : '비공유' %>
                                                </button>
                                            </form>
                                        </td>
                                        <td>
                                            <div class="btn-group">
                                                <a href="/instructor/sites/<%= s.id %>/edit"
                                                    class="btn btn-outline btn-sm" title="수정">✏️</a>
                                                <form method="POST" action="/instructor/sites/<%= s.id %>/delete"
                                                    style="display:inline;" onsubmit="return confirm('정말 삭제하시겠습니까?')">
                                                    <button type="submit" class="btn btn-danger btn-sm">🗑️</button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>

        <!-- Shared sites from other instructors -->
        <% if (sharedSites.length> 0) { %>
            <div class="card mt-2">
                <div class="card-header">
                    <span class="card-title">🤝 다른 강사가 공유한 사이트 (<%= sharedSites.length %>)</span>
                </div>
                <div class="table-wrap">
                    <table>
                        <thead>
                            <tr>
                                <th>슬러그</th>
                                <th>이름</th>
                                <th>URL</th>
                                <th>설명</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% sharedSites.forEach(s=> { %>
                                <tr>
                                    <td><code><%= s.slug %></code></td>
                                    <td>
                                        <strong>
                                            <%= s.name %>
                                        </strong>
                                        <span class="badge badge-info" style="margin-left: 0.5rem;">
                                            <%= s.creator_login %>
                                        </span>
                                    </td>
                                    <td class="text-sm">
                                        <%= s.url %>
                                    </td>
                                    <td class="text-sm text-muted">
                                        <%= s.description || '-' %>
                                    </td>
                                </tr>
                                <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
            <% } %>

                <%- include('../partials/footer') %>