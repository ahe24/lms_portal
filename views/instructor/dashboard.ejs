<%- include('../partials/head') %>
    <%- include('../partials/sidebar') %>

        <div class="page-header flex-between">
            <div>
                <h1>강사 대시보드</h1>
                <p>내 강의 및 수강생 현황</p>
            </div>
            <a href="/instructor/courses/new" class="btn btn-primary">➕ 강의 개설</a>
        </div>

        <% if (courses.length===0) { %>
            <div class="card">
                <div class="empty-state">
                    <div class="empty-icon">📝</div>
                    <h3>개설된 강의가 없습니다</h3>
                    <p class="text-muted mt-1">새 강의를 개설해보세요</p>
                    <a href="/instructor/courses/new" class="btn btn-primary mt-2">➕ 강의 개설</a>
                </div>
            </div>
            <% } else { %>
                <div class="course-grid">
                    <% courses.forEach((c, index)=> { %>
                        <div class="course-card v<%= (index % 6) + 1 %>">
                            <div class="course-card-top">
                                <h3>
                                    <%= c.title %>
                                        <% if (c.instructor_id !==user.id) { %>
                                            <span class="badge badge-info"
                                                style="font-size: 0.65rem; margin-left: 0.5rem; vertical-align: middle;">
                                                주강사: <%= c.instructor_name %>
                                            </span>
                                            <% } else { %>
                                                <span class="badge"
                                                    style="background: rgba(255,255,255,0.1); color: var(--text-muted); font-size: 0.65rem; margin-left: 0.5rem; vertical-align: middle;">
                                                    내 강의
                                                </span>
                                                <% } %>
                                </h3>
                                <div class="course-card-icons">
                                    <a href="/instructor/courses/<%= c.id %>/edit" class="icon-btn" title="수정">✏️</a>
                                    <form method="POST" action="/instructor/courses/<%= c.id %>/delete"
                                        style="display:inline;" onsubmit="return confirm('강의를 삭제하시겠습니까?')">
                                        <button type="submit" class="icon-btn" title="삭제">🗑️</button>
                                    </form>
                                </div>
                            </div>
                            <p>
                                <%= c.description || '설명 없음' %>
                            </p>
                            <div class="course-meta">
                                <span>
                                    <span title="연결된 수강생"><span class="badge badge-success">
                                            <%= c.approved_count %> 수강
                                        </span></span>
                                    <% if (c.pending_count> 0) { %>
                                        <span class="badge badge-warning">
                                            <%= c.pending_count %> 대기
                                        </span>
                                        <% } %>
                                </span>
                                <div class="btn-group">
                                    <a href="/instructor/courses/<%= c.id %>/students" class="btn btn-primary btn-sm">👥
                                        수강생 관리</a>
                                    <a href="/instructor/courses/<%= c.id %>/edit" class="btn btn-outline btn-sm">⚙️ 강의
                                        설정</a>
                                </div>
                            </div>

                            <div class="asset-section">
                                <% if (c.materials.length> 0) { %>
                                    <div class="mb-1">
                                        <span class="asset-label">📽️ 강의 슬라이드</span>
                                        <div class="asset-list">
                                            <% c.materials.forEach(m=> { %>
                                                <a href="/materials/<%= m.id %>/view?courseId=<%= c.id %>"
                                                    target="_blank" class="btn btn-material btn-sm">📽️ <%= m.title %>
                                                </a>
                                                <% }); %>
                                        </div>
                                    </div>
                                    <% } %>

                                        <% const internalSites=c.sites.filter(s=> !s.is_public);
                                            const externalSites = c.sites.filter(s => s.is_public);
                                            %>
                                            <% if (internalSites.length> 0) { %>
                                                <div class="mb-1">
                                                    <span class="asset-label">🔒 내부 강의 사이트</span>
                                                    <div class="asset-list">
                                                        <% internalSites.forEach(s=> { %>
                                                            <a href="/site/<%= s.slug %>" target="_blank"
                                                                class="btn btn-site btn-sm">
                                                                <%= s.name %>
                                                            </a>
                                                            <% }); %>
                                                    </div>
                                                </div>
                                                <% } %>
                                                    <% if (externalSites.length> 0) { %>
                                                        <div class="mb-1">
                                                            <span class="asset-label">🌐 외부 참고 사이트</span>
                                                            <div class="asset-list">
                                                                <% externalSites.forEach(s=> { %>
                                                                    <a href="<%= s.url %>" target="_blank"
                                                                        class="btn btn-site btn-sm"
                                                                        style="border-color: var(--info, #38bdf8); color: var(--info, #38bdf8);">
                                                                        <%= s.name %>
                                                                    </a>
                                                                    <% }); %>
                                                            </div>
                                                        </div>
                                                        <% } %>
                            </div>
                        </div>
                        <% }); %>
                </div>
                <% } %>

                    <!-- Other Instructors' Courses Section -->
                    <div class="page-header" style="margin-top: 4rem;">
                        <h2>타 강사 강의 목록</h2>
                        <p class="text-muted">다른 강사님이 개설한 강의를 참고할 수 있습니다</p>
                    </div>

                    <% if (otherCourses.length===0) { %>
                        <div class="card">
                            <div class="empty-state" style="padding: 2rem;">
                                <div class="empty-icon" style="font-size: 2rem; margin-bottom: 0.5rem;">🔍</div>
                                <h3 style="font-size: 1rem;">표시할 다른 강의가 없습니다</h3>
                            </div>
                        </div>
                        <% } else { %>
                            <div class="course-grid">
                                <% otherCourses.forEach((c, index)=> { %>
                                    <div class="course-card v<%= (index % 6) + 1 %>">
                                        <div class="course-card-top">
                                            <div>
                                                <h3>
                                                    <%= c.title %>
                                                </h3>
                                                <div class="text-xs text-muted mt-1"
                                                    style="display: flex; align-items: center; gap: 0.5rem;">
                                                    <span
                                                        style="background: rgba(255,255,255,0.1); padding: 2px 8px; border-radius: 4px; font-size: 0.75rem;">
                                                        👨‍🏫 <%= c.instructor_name %>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                        <p class="text-sm mt-1 mb-2">
                                            <%= c.description || '설명 없음' %>
                                        </p>

                                        <div class="course-meta">
                                            <span class="badge badge-secondary"
                                                style="background: var(--bg-secondary); border: 1px solid var(--border-color);">
                                                <%= c.approved_count %>명 수강생
                                            </span>
                                        </div>

                                        <div class="asset-section mt-2">
                                            <% if (c.materials.length> 0) { %>
                                                <div>
                                                    <span class="asset-label">📽️ 강의 슬라이드</span>
                                                    <div class="asset-list">
                                                        <% c.materials.forEach(m=> { %>
                                                            <a href="/materials/<%= m.id %>/view?courseId=<%= c.id %>"
                                                                target="_blank" class="btn btn-outline btn-sm"
                                                                style="border-color: var(--warning); color: var(--warning);">
                                                                <%= m.title %>
                                                            </a>
                                                            <% }); %>
                                                    </div>
                                                </div>
                                                <% } %>
                                                    <% const internalSites2=c.sites.filter(s=> !s.is_public);
                                                        const externalSites2 = c.sites.filter(s => s.is_public);
                                                        %>
                                                        <% if (internalSites2.length> 0) { %>
                                                            <div class="mb-1">
                                                                <span class="asset-label">🔒 내부 강의 사이트</span>
                                                                <div class="asset-list">
                                                                    <% internalSites2.forEach(s=> { %>
                                                                        <a href="/site/<%= s.slug %>" target="_blank"
                                                                            class="btn btn-outline btn-sm"
                                                                            style="border-color: var(--accent); color: var(--accent);">
                                                                            <%= s.name %>
                                                                        </a>
                                                                        <% }); %>
                                                                </div>
                                                            </div>
                                                            <% } %>
                                                                <% if (externalSites2.length> 0) { %>
                                                                    <div class="mb-1">
                                                                        <span class="asset-label">🌐 외부 참고 사이트</span>
                                                                        <div class="asset-list">
                                                                            <% externalSites2.forEach(s=> { %>
                                                                                <a href="<%= s.url %>" target="_blank"
                                                                                    class="btn btn-outline btn-sm"
                                                                                    style="border-color: var(--info, #38bdf8); color: var(--info, #38bdf8);">
                                                                                    <%= s.name %>
                                                                                </a>
                                                                                <% }); %>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>
                                        </div>
                                    </div>
                                    <% }); %>
                            </div>
                            <% } %>

                                <%- include('../partials/footer') %>