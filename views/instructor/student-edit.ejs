<%- include('../partials/head') %>
    <%- include('../partials/sidebar') %>

        <div class="page-header flex-between">
            <div>
                <h1>수강생 정보 수정</h1>
                <p>강의: <strong>
                        <%= course.title %>
                    </strong></p>
            </div>
            <a href="/instructor/courses/<%= course.id %>/students" class="btn btn-outline btn-sm">← 수강생 목록</a>
        </div>

        <div class="card" style="max-width:560px;">
            <% if (error) { %>
                <div class="alert alert-error">⚠️ <%= error %>
                </div>
                <% } %>
                    <% if (success) { %>
                        <div class="alert alert-success">✅ <%= success %>
                        </div>
                        <% } %>

                            <form method="POST" action="/instructor/enrollments/<%= enrollmentId %>/edit-student">
                                <div class="form-group">
                                    <label class="form-label">아이디</label>
                                    <input type="text" class="form-input" value="<%= student.login_id %>" disabled>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">이름 *</label>
                                        <input type="text" name="name" class="form-input" value="<%= student.name %>"
                                            required>
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">영문 이름</label>
                                        <input type="text" name="name_en" class="form-input"
                                            value="<%= student.name_en || '' %>">
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">이메일</label>
                                        <input type="email" name="email" class="form-input"
                                            value="<%= student.email || '' %>">
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">소속</label>
                                        <input type="text" name="affiliation" class="form-input"
                                            value="<%= student.affiliation || '' %>">
                                    </div>
                                </div>
                                <div class="form-row">
                                    <div class="form-group">
                                        <label class="form-label">전화번호</label>
                                        <input type="text" name="phone" id="phone" class="form-input"
                                            value="<%= student.phone || '' %>" maxlength="13">
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label">생년월일</label>
                                        <input type="text" name="birth_date" id="birth_date" class="form-input"
                                            value="<%= student.birth_date || '' %>" maxlength="8" placeholder="YYMMDD">
                                    </div>
                                </div>
                                <div class="flex gap-2">
                                    <button type="submit" class="btn btn-primary">저장</button>
                                    <a href="/instructor/courses/<%= course.id %>/students"
                                        class="btn btn-outline">취소</a>
                                </div>
                            </form>
        </div>

        <script>
            document.getElementById('phone').addEventListener('input', function () {
                let d = this.value.replace(/\D/g, '');
                if (d.length > 11) d = d.slice(0, 11);
                if (d.length <= 3) this.value = d;
                else if (d.length <= 7) this.value = d.slice(0, 3) + '-' + d.slice(3);
                else this.value = d.slice(0, 3) + '-' + d.slice(3, 7) + '-' + d.slice(7);
            });
        </script>

        <%- include('../partials/footer') %>